{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "I Love Norton Commander",
  "version": "0.1.1",
  "identifier": "com.georgewebdev.ilovenc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "I Love Norton Commander",
        "width": 1200,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "maximized": true,
        "fullscreen": true,
        "decorations": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "I Love Norton Commander"
      }
    }
  }
}
